# ─── TrustOps Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── ML Microservice (Python / Railway / Render) ──────────────────────────────
# URL of the deployed TrustOps ML microservice
# - Local dev: http://localhost:8000
# - Railway:   https://your-service.up.railway.app
# - Render:    https://your-service.onrender.com
ML_API_URL=http://localhost:8000

# ── Node Express Dev Server ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Ollama (Optional — Chat Enhancement) ─────────────────────────────────────
# If set, /api/chat will use Ollama to paraphrase ML results in richer English.
# If unset, the template formatter runs instead (always works, offline-safe).
# Example: OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=

# ── Vercel Frontend Build ─────────────────────────────────────────────────────
# These are read by Vite at build time (must be prefixed VITE_)
# Set them in: Vercel Dashboard → Project → Settings → Environment Variables
# VITE_ML_API_URL=https://your-service.up.railway.app
